{
  "name": "nextjs-workspace",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter hono-api dev",
    "dev:web": "pnpm --filter nextjs dev",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.9"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
